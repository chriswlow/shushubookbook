{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "functions": {
    "src/app/api/prepare-quotes/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/prepare-quotes",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/send-quotes",
      "schedule": "0 9 * * *"
    }
  ]
}
